{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://posbillingapp-production.up.railway.app/api/$1"
        },
        {
            "source": "/images/(.*)",
            "destination": "https://posbillingapp-production.up.railway.app/images/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}