{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Information"
        }
    },
    "ConnectionStrings": {
        "DefaultConnection": "Server=localhost;Database=pos_db;Uid=root;Pwd=YOUR_DB_PASSWORD;"
    },
    "EmailSettings": {
        "SmtpHost": "smtp.gmail.com",
        "SmtpPort": 587,
        "SenderEmail": "YOUR_EMAIL@gmail.com",
        "SenderPassword": "YOUR_APP_PASSWORD",
        "SenderName": "POS Billing App"
    },
    "Jwt": {
        "Key": "YOUR_LONG_RANDOM_SECRET_KEY",
        "Issuer": "pos_billing_api",
        "Audience": "pos_billing_users",
        "DurationInMinutes": 10080
    },
    "Razorpay": {
        "KeyId": "YOUR_RAZORPAY_KEY_ID",
        "KeySecret": "YOUR_RAZORPAY_KEY_SECRET",
        "WebhookSecret": "",
        "BaseUrl": "https://api.razorpay.com/v1",
        "IsTestMode": true,
        "PayoutAccountNumber": "YOUR_PAYOUT_ACCOUNT",
        "EncryptionKey": "YOUR_ENCRYPTION_KEY"
    },
    "Subscription": {
        "PlanAmountINR": 299,
        "TrialDays": 20,
        "SubscriptionDays": 30,
        "FrontendUrl": "http://localhost:5173"
    },
    "AllowedHosts": "*"
}