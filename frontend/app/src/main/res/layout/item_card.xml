<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#0F172A"
    app:cardCornerRadius="24dp"
    app:cardElevation="6dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvCardType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.6"
            android:text="VISA"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnDeleteCard"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="#44FFFFFF" />

        <TextView
            android:id="@+id/tvCardNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvCardType"
            android:layout_marginTop="20dp"
            android:letterSpacing="0.2"
            android:text="XXXX XXXX XXXX 1234"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCardHolder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvCardNumber"
            android:layout_marginTop="24dp"
            android:text="CARD HOLDER NAME"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCardExpiry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvCardNumber"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="24dp"
            android:text="12/26"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <ImageView
            android:id="@+id/ivPrimaryCheck"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_above="@id/tvCardExpiry"
            android:layout_alignParentEnd="true"
            android:layout_marginBottom="4dp"
            android:src="@android:drawable/checkbox_on_background"
            android:visibility="gone"
            app:tint="#4F46E5" />

    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>
