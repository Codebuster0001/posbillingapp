<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:columnCount="3"
    android:rowCount="4"
    android:padding="16dp"
    android:alignmentMode="alignBounds"
    android:useDefaultMargins="true">

    <!-- Row 0 -->
    <Button android:text="7" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp"/>
    <Button android:text="8" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp"/>
    <Button android:text="9" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp"/>

    <!-- Row 1 -->
    <Button android:text="4" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp"/>
    <Button android:text="5" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp"/>
    <Button android:text="6" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp"/>

    <!-- Row 2 -->
    <Button android:text="1" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp"/>
    <Button android:text="2" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp"/>
    <Button android:text="3" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp"/>

    <!-- Row 3 -->
    <Button android:text="." style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp"/>
    <Button android:text="0" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp"/>
    <Button android:text="C" style="@style/Widget.MaterialComponents.Button.TextButton" android:textSize="24sp"/>

</GridLayout>
